<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">


        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/settings_title"
            android:textColor="@color/primary_yellow"
            android:textSize="26sp"
            android:textStyle="bold" />


        <Switch
            android:id="@+id/switchDarkMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@drawable/input_background"
            android:layout_marginBottom="20dp"
            android:text="@string/settings_dark_mode" />


        <Switch
            android:id="@+id/switchNotifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@drawable/input_background"
            android:layout_marginBottom="20dp"
            android:text="@string/settings_notifications" />


        <TextView
            android:id="@+id/textViewFontSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_font_size"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerFontSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@drawable/input_background"
            android:layout_marginBottom="20dp" />

        <!-- Language -->
        <TextView
            android:id="@+id/textViewLanguage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_language"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@drawable/input_background"
            android:layout_marginBottom="20dp" />

        <!-- Clear All Data -->
        <TextView
            android:id="@+id/textViewClearAllData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_clear_data"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnClearData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_btn_delete"
            android:backgroundTint="#D32F2F"
            android:textColor="@android:color/white"
            android:layout_marginBottom="20dp" />

        <!-- Privacy Policy -->
        <TextView
            android:id="@+id/textViewPrivacyPolicy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_privacy_policy"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnPrivacyPolicy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_btn_view"
            android:layout_marginBottom="32dp" />

        <!-- App Version -->
        <TextView
            android:id="@+id/textViewAppVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_app_version"
            android:textColor="@android:color/darker_gray"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>

</ScrollView>
